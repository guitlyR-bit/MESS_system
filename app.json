{
  "expo": {
    "name": "MESS",
    "slug": "tennis-platform",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "messapp",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cz.mess.tennisplatform"
    },
    "android": {
      "package": "cz.mess.tennisplatform"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
